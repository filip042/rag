spring:
  application:
    name: mainApp
  http:
    client:
      connect-timeout: 1200s
      read-timeout: 1200s
  ai:
    retry:
      max-attempts: 3
      backoff:
        initial-interval: 3s
        multiplier: 2
    openai:
      api-key: ${OPENAI_API_KEY:}
      chat:
        options:
          max-tokens: 1000
    anthropic:
      api-key: ${ANTHROPIC_API_KEY}
  datasource:
    url: ${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5432/appdb}
    username: ${SPRING_DATASOURCE_USERNAME:appuser}
    password: ${SPRING_DATASOURCE_PASSWORD:apppass}
    driverClassName: org.postgresql.Driver
  jpa:
    database-platform: org.hibernate.dialect.PostgreSQLDialect
    hibernate:
      ddl-auto: update
    defer-datasource-initialization: true
  sql:
    init:
      mode: never
  main:
    allow-bean-definition-overriding: true
app:
  base-url: http://localhost:8080
  llm:
    provider: ollama
    base-url: ${OLLAMA_BASE_URL:http://localhost:11434}
    api-key: ${OPENAI_API_KEY:}
    chat:
      model: ${OLLAMA_CHAT_MODEL:deepseek-r1:1.5b}
      temperature: 0.2
    embedding:
      model: ${OLLAMA_EMBED_MODEL:mxbai-embed-large:latest}
  vectorstore:
    provider: elasticsearch
    uris: ${SPRING_ELASTICSEARCH_URIS:http://localhost:9200}
    username:
    password:
    initialize-schema: true
    index-name: rag_idx
    dimensions: 1024
    similarity: cosine
  rag:
    query:
      max-query-length: 160
      search-prefix: "Represent this sentence for searching relevant passages: "
      document-prefix: "search_document: "
    splitter:
      chunk-size: 400
      min-chunk-size-chars: 10
      min-chunk-length-to-embed: 50
      max-num-chunks: 10000
      keep-separator: true
      overlap-tokens: 50
  api-urls:
    base: /app
    add: /add
    answer: /answer
    ask: /ask
    delete: /delete
    status: /status
  frontend-urls:
    base: /user
    answer: /answer
    chat: /chat
    dashboard: /dashboard
    delete-project: /deleteProject
    load: /load
    login: /login
    logout: /logout
    new-project: /newProject
    new-user: /newUser
  ollama:
    username: <username>
    password: <password>
server:
  error:
    whitelabel:
      enabled: false
logging:
  file:
    name: logs/app.log
  logback:
    rollingpolicy:
      max-file-size: 10MB
      max-history: 30
  level:
    root: INFO
    cz.cuni.mff.hanaf: DEBUG
    org.springframework.ai.openai.api.OpenAiApi: TRACE
    org.springframework.web.client.RestClient: DEBUG
    org.hibernate.SQL: DEBUG
    org.hibernate.orm.jdbc.bind: TRACE