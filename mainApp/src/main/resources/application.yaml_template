spring:
  application:
    name: mainApp
  http:
    client:
      connect-timeout: 1200s
      read-timeout: 1200s
  elasticsearch:
    uris: http://localhost:9200
  #    username: <elasticsearch username>
  #    password: <elasticsearch password>
  ai:
    openai:
      chat:
        options:
          model: <chat model>
          temperature: 0.7
          http-headers:
            Authorization: <username and password>
        base-url: <chat model url>
      embedding:
        base-url: http://localhost:11434 # ollama default
        options:
          model: <embedding model>
      api-key: o
    vectorstore:
      elasticsearch:
        initialize-schema: true
        index-name: <index name>
        dimensions: <embedding model dimensions>
        similarity: cosine