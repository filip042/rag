spring:
  application:
    name: mainApp
  http:
    client:
      connect-timeout: 1200s
      read-timeout: 1200s
  ai:
    openai:
      api-key: <api key for tests>
      chat:
        options:
          max-tokens: 1000 <might be unnecessary>
  datasource:
    url: jdbc:h2:mem:testdb #file:/data/demo
    username: <username>
    password: <password>
    driverClassName: org.h2.Driver
  jpa:
    database-platform: org.hibernate.dialect.H2Dialect
    hibernate:
      ddl-auto: create
    defer-datasource-initialization: true
  h2:
    console:
      enabled: true
  sql:
    init:
      mode: always
  main:
    allow-bean-definition-overriding: true <todo probably remove when seperation into dependencies done>
app:
  base-url: http://localhost:8080
  llm:
    provider: <provider>
    base-url: <ollama base url>
    api-key: <openAi api key>
    chat:
      model: <chat model>
      temperature: <llm temperature>
    embedding:
      model: <embedding model>
  vectorstore:
    provider: <vectorstore provider>
    uris: http://localhost:9200
    username: <todo check if set>
    password: <todo ditto>
    initialize-schema: true
    index-name: <index name>
    dimensions: <index dimensions, corresponds to embedding model>
    similarity: cosine
  api-urls:
    base: /app
    add: /add
    answer: /answer
    ask: /ask
    delete: /delete
    status: /status
  frontend-urls:
    base: /user
    answer: /answer
    chat: /chat
    dashboard: /dashboard
    delete-project: /deleteProject
    load: /load
    login: /login
    logout: /logout
    new-project: /newProject
    new-user: /newUser
  ollama:
    username: <username>
    password: <password>
server:
  error:
    whitelabel:
      enabled: false