spring:
  application:
    name: mainApp
  http:
    client:
      connect-timeout: 1200s
      read-timeout: 1200s
  elasticsearch:
    uris: http://localhost:9200
  #    username: <elasticsearch username>
  #    password: <elasticsearch password>
  ai:
    openai:
      api-key: temp
    vectorstore:
      elasticsearch:
        initialize-schema: true
        index-name: <index name>
        dimensions: <embedding model dimensions>
        similarity: cosine
  datasource:
    url: jdbc:h2:mem:testdb  # for in-memory database
    username: <username>
    password: <password>
    driverClassName: org.h2.Driver
  jpa:
    database-platform: <database platform>
    hibernate:
      ddl-auto: create
    defer-datasource-initialization: true  # create tables before sql commands from data.sql are executed
  h2:
    console:
      enabled: true
  sql:
    init:
      mode: always
app:
  base-url: http://localhost:8080
  llm:
    provider: <llm provider>
    base-url: <url for ollama>
    api-key: <api key for openAi>
    chat:
      model: <chat model>
      temperature: <model temperature>
    embedding:
      model: <embedding model>
  api-urls:
    base: /app
    add: /add
    answer: /answer
    ask: /ask
    delete: /delete
    status: /status
  frontend-urls:
    base: /user
    answer: /answer
    chat: /chat
    dashboard: /dashboard
    delete-project: /deleteProject
    load: /load
    login: /login
    logout: /logout
    new-project: /newProject
    new-user: /newUser
  ollama:
    username: <username>
    password: <password>
server:
  error:
    whitelabel:
      enabled: false