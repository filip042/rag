# LLM and vector store providers
LLM_PROVIDER=ollama
VECTORSTORE_PROVIDER=elasticsearch

# Ollama provider (used with docker-compose.ollama.yml)
OLLAMA_CHAT_MODEL=deepseek-r1:1.5b
OLLAMA_EMBED_MODEL=mxbai-embed-large:latest

# OpenAI provider (used with docker-compose.openai.yml)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Anthropic (used for the test judge, independent of the active LLM provider)
ANTHROPIC_API_KEY=

# Username and password, if required by the LLM provider
LLM_USERNAME=
LLM_PASSWORD=

# Run `docker compose up` without repeating -f flags each time. Use colons instead of semicolons on Windows.
COMPOSE_FILE=docker-compose.yml:docker-compose.ollama.yml:docker-compose.elasticsearch.yml